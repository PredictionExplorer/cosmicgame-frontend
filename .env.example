# Network to use: local | sepolia | mainnet
NEXT_PUBLIC_NETWORK=sepolia

# Infura API key for Arbitrum mainnet RPC
NEXT_PUBLIC_INFURA_KEY=

# Override the default RPC URL for the selected network (optional)
# NEXT_PUBLIC_RPC_URL=

# Override the default backend API URL for the selected network (optional)
# NEXT_PUBLIC_API_URL=

# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Google Analytics 4 measurement ID (optional)
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Sentry DSN for error reporting (optional)
# NEXT_PUBLIC_SENTRY_DSN=
