# Required: no defaults for network or API/RPC URLs (avoids wrong backend/chain)
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_API_URL=https://api.example.com/api/cosmicgame/
NEXT_PUBLIC_RPC_URL=https://arbitrum-mainnet.infura.io/v3/YOUR_KEY

# Infura API key (only if using Infura RPC)
NEXT_PUBLIC_INFURA_KEY=

# WalletConnect Project ID (required by RainbowKit for WalletConnect v2)
# - Local testing: Create a free project at https://cloud.walletconnect.com (no card, ~1 min).
#   One project ID works for both local dev and production; "project" = app identity, not deployment.
# - If you leave this unset: a placeholder is used. You'll see 403 "Failed to fetch usage" in the
#   console; you can ignore it. Injected wallets (MetaMask, etc.) still work; QR/mobile may be limited.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# NEXT_PUBLIC_SENTRY_DSN=
